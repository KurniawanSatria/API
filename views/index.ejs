<h1 class="text-3xl font-bold">
<span class="text-primary ml-7">CYBER</span><span class="text-secondary">API</span>
</h1>
<label for="sidebar-drawer" class="btn btn-square btn-sm drawer-button"><i class="bx bx-x text-sm"></i>
</label>
</div>

<ul class="menu text-lg space-y-1 w-full rounded-box">
<li><a class="active"><i class="bx bx-dashboard bx-sm mr-2"></i> Dashboard</a></li>

<li>
<details>
<summary><i class='bx bx-psychology bx-sm mr-2'></i> AI</summary>
<ul class="pl-4 text-sm">
<li><a href="/v1/ai/gpt-4o">GPT-4o</a></li>
<li><a href="/v1/ai/gpt-4o-mini">GPT-4o-Mini</a></li>
<li><a href="/v1/ai/claude-3.5-haiku">Claude-3.5-Haiku</a></li>
<li><a href="/v1/ai/claude-3.7-sonnet">Claude-3.7-Sonnet</a></li>
<li><a href="/v1/removebg">Remove Background</a></li>
<li><a href="/v1/enhance">Image Enhancer</a></li>
</ul>
</details>
</li>

<li>
<details>
<summary><i class='bx bx-search-alt bx-sm mr-2'></i> Search</summary>
<ul class="pl-4 text-sm">
<li><a href="/v1/spotify">Spotify</a></li>
<li><a href="/v1/soundcloud">Soundcloud</a></li>
<li><a href="/v1/sugest">Lyrics Sugest</a></li>
<li><a href="/v1/lyrics">Lyrics Search</a></li>
</ul>
</details>
</li>

<li>
<details>
<summary><i class='bx bx-chevrons-down bx-sm mr-2'></i> Downloader</summary>
<ul class="pl-4 text-sm">
<li><a href="/v1/ytmp3">Youtube MP3</a></li>
<li><a href="/v1/ytmp4">Youtube MP4</a></li>
<li><a href="/v1/spotifydl">Spotify</a></li>
<li><a href="/v1/soundclouddl">Soundcloud</a></li>
</ul>
</details>
</li>

<li>
<details>
<summary><i class="bx bx-axe bx-sm mr-2"></i> Tools</summary>
<ul class="pl-4 text-base space-y-1">
<li><a href="/v1/qrcode">QR Code</a></li>
