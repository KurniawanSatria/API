</aside>
</div>


<!-- Main Content -->
<div class="drawer-content p-4">
<!-- Mobile Header -->
<header class="navbar bg-base-100 rounded-box shadow mb-4 lg:hidden">
<div class="flex-1">
<h1 class="text-xl font-bold ml-2"> <!-- Increased from text-2xl to text-3xl -->
<span class="animate-pulse">⟨</span>
<span class="text-primary">CYBER</span><span class="text-secondary">API</span>
<span class="animate-pulse">⟩</span>
</h1>
</div>
<div class="flex-none gap-2">
<label class="swap swap-rotate">
<input type="checkbox" class="theme-controller" value="dracula" />
<i class="bx bx-sun swap-off text-2xl"></i> <!-- Increased icon size -->
<i class="bx bx-moon swap-on text-2xl"></i> <!-- Increased icon size -->
</label>
<label for="sidebar-drawer" class="btn btn-square btn-ghost">
<i class="bx bx-sidebar text-2xl"></i> <!-- Increased icon size -->
</label>
</div>
</header>
<!-- DESKTOP HEADER (hidden pas mobile) -->
<header class="navbar bg-base-100 rounded-box shadow mb-4 hidden lg:flex">
<div class="flex-1">
<h1 class="text-xl font-bold ml-3">
<span class="animate-pulse">⟨</span>
<span class="text-primary">CYBER</span><span class="text-secondary">API</span>
<span class="animate-pulse">⟩</span>
</h1>
</div>
<div class="flex-none gap-4 mr-3">
<label class="swap swap-rotate">
<input type="checkbox" class="theme-controller" value="dracula" />
<i class="bx bx-sun swap-off text-xl"></i>
<i class="bx bx-moon swap-on text-xl"></i>
</label>
</div>
</header>

<!-- Dashboard Content -->
<div class="grid gap-4">
<!-- Status Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">

<div class="card bg-base-100 shadow-xl">
<div class="card-body">
<div class="flex justify-between items-center">
<div>
<h3 class="card-title text-lg">UPTIME</h3> <!-- Increased to text-lg -->
<p id="uptime" class="text-3xl font-bold countdown">
<span class="uptime-h"></span>:
<span class="uptime-m"></span>:
<span class="uptime-s"></span>
</p>
</div>
<div class="btn btn-secondary btn-circle">
<i class="bx bx-timer text-xl"></i> <!-- Increased icon size -->
</div>
</div>
</div>
</div>
<div class="card bg-base-100 shadow-xl">
<div class="card-body">
<div class="flex justify-between items-center">
<div>
<h3 class="card-title text-lg">API REQUESTS</h3> <!-- Increased to text-lg -->
<p id="api-request-count" class="text-3xl font-bold">5,000</p> <!-- Increased to text-3xl -->
</div>
<div class="btn btn-primary btn-circle">
<i class="bx bx-arrow-big-up text-xl"></i> <!-- Increased icon size -->
</div>
</div>
</div>
</div>


<div class="card bg-base-100 shadow-xl">
<div class="card-body">
<div class="flex justify-between items-center">
<div>
<h3 class="card-title text-lg">CURRENT TIME</h3>
<p id="current-time" class="text-3xl font-bold countdown">
<span class="current-time-h"></span>:
<span class="current-time-m"></span>:
<span class="current-time-s"></span>
</p>
</div>
<div class="btn btn-success btn-circle">
<i class="bx bx-clock-12 text-xl"></i>
</div>
</div>
</div>
</div>

</div>

<!-- System Performance -->
<div class="card bg-base-100 shadow-xl">
<div class="card-body">
<h3 class="card-title text-lg">SYSTEM PERFORMANCE</h3> <!-- Increased to text-lg -->
<div class="grid gap-4">
<div>
<div class="flex justify-between mb-2">
<span class="text-base">CPU Usage</span> <!-- Increased to text-base -->
<span id="cpu" class="text-primary font-semibold text-base"></span> <!-- Increased to text-base -->
</div>
<progress class="progress progress-primary" value="0" max="100"></progress>
</div>
<div>
<div class="flex justify-between mb-2">
<span class="text-base">Memory Usage</span> <!-- Increased to text-base -->
<span id="mem" class="text-secondary font-semibold text-base"></span> <!-- Increased to text-base -->
</div>
<progress class="progress progress-secondary" value="0" max="100"></progress>
</div>
<div>
<div class="flex justify-between mb-2">
<span class="text-base">Disk Usage</span> <!-- Increased to text-base -->
<span id="disk" class="text-success font-semibold text-base"></span> <!-- Increased to text-base -->
</div>
<progress class="progress progress-success" value="0" max="100"></progress>
</div>
<div>
<div class="flex justify-between mb-2">
<span class="text-base">Heap Usage</span> <!-- Increased to text-base -->
<span id="heap" class="text-warning font-semibold text-base"></span> <!-- Increased to text-base -->
</div>
<progress class="progress progress-warning" value="0" max="100"></progress>
</div>
</div>
</div>
</div>
</div>
</div>
</div>

<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="scripts.js"></script>
</body>
</html>